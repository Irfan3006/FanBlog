---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { getPostBySlug } from "../../lib/posts";

// Guard: redirect to login if session invalid
const isAdmin = Astro.cookies.get("admin_session")?.value === "true";
if (!isAdmin) {
    return Astro.redirect("/admin/login");
}

const { searchParams } = Astro.url;
const slug = searchParams.get("slug");

let post = null;
if (slug) {
    post = await getPostBySlug(slug);
}

const isEditing = !!post;
---

<BaseLayout title={isEditing ? `Editing: ${post?.title}` : "New Post"}>
    <div class="editor-container container">
        <header class="editor-header">
            <h1>{isEditing ? "Edit Post" : "Create New Post"}</h1>
            <div class="header-actions">
                <a href="/admin" class="btn btn-outline">Cancel</a>
                <button id="save-btn" class="btn btn-primary">{isEditing ? "Update Post" : "Publish Post"}</button>
            </div>
        </header>

        <div class="editor-layout">
            <!-- Sidebar for Metadata -->
            <aside class="editor-sidebar">
                <div class="form-group">
                    <label for="title">Title</label>
                    <input type="text" id="title" placeholder="Post title..." value={post?.title || ""} required />
                </div>

                <div class="form-group">
                    <label for="description">Description</label>
                    <textarea id="description" placeholder="Short summary..." rows="2">{post?.description || ""}</textarea>
                </div>

                <div class="form-group">
                    <label for="author">Author</label>
                    <input type="text" id="author" value={post?.author || "Irfan"} />
                </div>

                <div class="form-group">
                    <label for="category">Category</label>
                    <input type="text" id="category" placeholder="Tech, Lifestyle, etc." value={post?.category || "General"} />
                </div>

                <div class="form-group">
                    <label for="tags">Tags (comma separated)</label>
                    <input type="text" id="tags" placeholder="Astro, Web, etc." value={post?.tags?.join(", ") || ""} />
                </div>

                <div class="form-group">
                    <label for="image-upload">Featured Image</label>
                    <input type="file" id="image-upload" accept="image/*" />
                    <input type="hidden" id="image-url" value={post?.image || ""} />
                    {
                        post?.image && (
                            <div class="image-preview" id="upload-preview">
                                <img src={post.image} alt="Preview" />
                            </div>
                        )
                    }
                </div>

                {isEditing && <input type="hidden" id="slug" value={post?.slug} />}
                {isEditing && <input type="hidden" id="date" value={post?.date} />}
            </aside>

            <!-- Main Editor -->
            <main class="editor-main">
                <div class="tabs">
                    <div class="tab-group">
                        <button class="tab-btn active" data-tab="edit">Editor</button>
                        <button class="tab-btn" data-tab="preview">Preview</button>
                    </div>
                    <div class="toolbar">
                        <button type="button" id="insert-image-btn" class="toolbar-btn" title="Insert Image">
                            <svg
                                xmlns="http://www.w3.org/2000/svg"
                                width="18"
                                height="18"
                                viewBox="0 0 24 24"
                                fill="none"
                                stroke="currentColor"
                                stroke-width="2"
                                stroke-linecap="round"
                                stroke-linejoin="round"
                                ><rect x="3" y="3" width="18" height="18" rx="2" ry="2"></rect><circle cx="8.5" cy="8.5" r="1.5"></circle><polyline
                                    points="21 15 16 10 5 21"></polyline></svg
                            >
                            Insert Image
                        </button>
                        <input type="file" id="editor-image-upload" accept="image/*" style="display: none;" />
                    </div>
                </div>

                <div id="edit-pane" class="pane active">
                    <textarea id="content" placeholder="Write your markdown here..." class="main-textarea">{post?.content || ""}</textarea>
                </div>

                <div id="preview-pane" class="pane markdown-body">
                    <!-- Preview content will be injected here -->
                </div>
            </main>
        </div>
    </div>
</BaseLayout>

<style>
    .editor-container {
        padding: 3rem 1.5rem;
    }
    .editor-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 2rem;
    }
    .header-actions {
        display: flex;
        gap: 1rem;
    }

    .editor-layout {
        display: grid;
        grid-template-columns: 300px 1fr;
        gap: 2rem;
    }

    .editor-sidebar {
        background: var(--card-bg);
        padding: 1.5rem;
        border-radius: 12px;
        border: 1px solid var(--border-color);
        height: fit-content;
    }

    .form-group {
        margin-bottom: 1.5rem;
    }
    .form-group label {
        display: block;
        font-weight: 600;
        margin-bottom: 0.5rem;
        font-size: 0.9rem;
    }
    .form-group input[type="text"],
    .form-group textarea {
        width: 100%;
        padding: 0.8rem;
        border-radius: 6px;
        border: 1px solid var(--border-color);
        background: var(--bg-color);
        color: var(--text-color);
        font-family: inherit;
    }

    .image-preview img {
        width: 100%;
        border-radius: 6px;
        margin-top: 1rem;
    }

    .editor-main {
        background: var(--card-bg);
        border-radius: 12px;
        border: 1px solid var(--border-color);
        display: flex;
        flex-direction: column;
        overflow: hidden;
        height: 70vh;
    }

    .tabs {
        display: flex;
        justify-content: space-between;
        align-items: center;
        border-bottom: 1px solid var(--border-color);
        background: var(--color-gray-100);
        padding-right: 1rem;
    }
    :global([data-theme="dark"]) .tabs {
        background: var(--color-gray-900);
    }
    .tab-group {
        display: flex;
    }
    .tab-btn {
        padding: 1rem 2rem;
        border: none;
        background: none;
        cursor: pointer;
        color: var(--text-color);
        font-weight: 600;
        opacity: 0.6;
    }
    .tab-btn.active {
        opacity: 1;
        border-bottom: 2px solid var(--color-primary);
        background: var(--card-bg);
    }

    .toolbar {
        display: flex;
        gap: 0.5rem;
    }

    .toolbar-btn {
        background: var(--bg-color);
        border: 1px solid var(--border-color);
        color: var(--text-color);
        padding: 0.4rem 0.8rem;
        border-radius: 6px;
        cursor: pointer;
        display: flex;
        align-items: center;
        gap: 0.5rem;
        font-size: 0.85rem;
        font-weight: 600;
        transition: all 0.2s;
    }

    .toolbar-btn:hover {
        border-color: var(--color-primary);
        color: var(--color-primary);
        background: rgba(255, 107, 0, 0.05);
    }

    .pane {
        display: none;
        padding: 1.5rem;
        flex: 1;
        overflow-y: auto;
    }
    .pane.active {
        display: block;
    }

    .main-textarea {
        width: 100%;
        height: 100%;
        border: none;
        background: none;
        color: var(--text-color);
        font-family: "Courier New", Courier, monospace;
        font-size: 1.1rem;
        resize: none;
        outline: none;
    }

    /* Markdown preview styling */
    .preview-pane {
        line-height: 1.6;
    }

    @media (max-width: 900px) {
        .editor-layout {
            grid-template-columns: 1fr;
        }
        .editor-main {
            height: 60vh;
        }
    }
</style>

<script>
    import { marked } from "marked";

    const select = (id: string) => document.getElementById(id) as HTMLInputElement;
    const contentEl = select("content");
    const previewEl = document.getElementById("preview-pane");
    const saveBtn = document.getElementById("save-btn");
    const uploadInput = select("image-upload");

    // Image Insertion in Editor
    const insertImageBtn = document.getElementById("insert-image-btn");
    const editorImageUpload = select("editor-image-upload");

    insertImageBtn?.addEventListener("click", () => {
        editorImageUpload.click();
    });

    editorImageUpload.addEventListener("change", async (e) => {
        const file = (e.target as HTMLInputElement).files?.[0];
        if (!file) return;

        insertImageBtn!.innerText = "Uploading...";
        insertImageBtn!.setAttribute("disabled", "true");

        const formData = new FormData();
        formData.append("file", file);

        const res = await fetch("/api/upload", {
            method: "POST",
            body: formData,
        });

        if (res.ok) {
            const data = await res.json();
            const markdownImage = `\n![Image Description](${data.url})\n`;

            // Insert at cursor position
            const startPos = contentEl.selectionStart || 0;
            const endPos = contentEl.selectionEnd || 0;
            const text = contentEl.value;

            contentEl.value = text.substring(0, startPos) + markdownImage + text.substring(endPos);

            // Focus back and move cursor
            contentEl.focus();
            const newCursorPos = startPos + markdownImage.length;
            contentEl.setSelectionRange(newCursorPos, newCursorPos);

            alert("Image inserted successfully");
        } else {
            alert("Upload failed");
        }

        insertImageBtn!.innerHTML = `<svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="18" height="18" rx="2" ry="2"/><circle cx="8.5" cy="8.5" r="1.5"/><polyline points="21 15 16 10 5 21"/></svg> Insert Image`;
        insertImageBtn!.removeAttribute("disabled");
    });

    // Tab Switching
    document.querySelectorAll(".tab-btn").forEach((btn) => {
        btn.addEventListener("click", () => {
            document.querySelectorAll(".tab-btn").forEach((b) => b.classList.remove("active"));
            document.querySelectorAll(".pane").forEach((p) => p.classList.remove("active"));

            btn.classList.add("active");
            const tab = btn.getAttribute("data-tab");
            if (tab === "preview") {
                const content = contentEl.value;
                previewEl!.innerHTML = marked.parse(content) as string;
            }
            document.getElementById(`${tab}-pane`)?.classList.add("active");
        });
    });

    // Image Upload
    uploadInput.addEventListener("change", async (e) => {
        const file = (e.target as HTMLInputElement).files?.[0];
        if (!file) return;

        const formData = new FormData();
        formData.append("file", file);

        const res = await fetch("/api/upload", {
            method: "POST",
            body: formData,
        });

        if (res.ok) {
            const data = await res.json();
            select("image-url").value = data.url;
            alert("Image uploaded successfully");
        } else {
            alert("Upload failed");
        }
    });

    // Save Post
    saveBtn?.addEventListener("click", async () => {
        const title = select("title").value;
        const author = select("author").value;
        const category = select("category").value;
        const description = select("description").value;
        const tags = select("tags").value;
        const content = contentEl.value;
        const image = select("image-url").value;

        // Check if editing
        const slugEl = select("slug");
        const method = slugEl ? "PUT" : "POST";
        const slug = slugEl ? slugEl.value : null;
        const date = select("date")?.value;

        if (!title || !content) {
            alert("Title and content are required");
            return;
        }

        const res = await fetch("/api/posts", {
            method,
            headers: { "Content-Type": "application/json" },
            body: JSON.stringify({ title, author, category, description, tags, content, image, slug, date }),
        });

        if (res.ok) {
            window.location.href = "/admin";
        } else {
            const err = await res.json();
            alert("Error: " + err.error);
        }
    });
</script>
