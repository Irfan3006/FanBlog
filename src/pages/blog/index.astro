---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { getAllPosts } from "../../lib/posts";
import BlogCard from "../../components/BlogCard.astro";

const posts = await getAllPosts();
const tags = [...new Set(posts.flatMap((post) => post.tags))].sort();

const { searchParams } = Astro.url;
const currentTag = searchParams.get("tag");

const filteredPosts = currentTag ? posts.filter((post) => post.tags.includes(currentTag)) : posts;
---

<BaseLayout title="Blog" description="Explore our articles, tutorials, and insights on the FanBlog.">
    <div class="container blog-archive">
        <header class="archive-header fade-in">
            <h1 class="archive-title">All Articles</h1>
            <p class="archive-subtitle">Curated insights on modern web development and design.</p>
        </header>

        <div class="archive-layout fade-in">
            <aside class="sidebar">
                <div class="sidebar-section">
                    <h3 class="sidebar-label">Search</h3>
                    <div class="search-box">
                        <input type="text" id="blog-search" placeholder="Type to search..." aria-label="Search articles" />
                        <svg
                            class="search-icon"
                            xmlns="http://www.w3.org/2000/svg"
                            width="20"
                            height="20"
                            viewBox="0 0 24 24"
                            fill="none"
                            stroke="currentColor"
                            stroke-width="2"
                            stroke-linecap="round"
                            stroke-linejoin="round"><circle cx="11" cy="11" r="8"></circle><line x1="21" y1="21" x2="16.65" y2="16.65"></line></svg
                        >
                    </div>
                </div>

                <div class="sidebar-section">
                    <h3 class="sidebar-label">Categories</h3>
                    <ul class="tag-list">
                        <li>
                            <a href="/blog" class={!currentTag ? "active" : ""}> All Posts </a>
                        </li>
                        {
                            tags.map((tag) => (
                                <li>
                                    <a href={`/blog?tag=${tag}`} class={currentTag === tag ? "active" : ""}>
                                        {tag}
                                    </a>
                                </li>
                            ))
                        }
                    </ul>
                </div>
            </aside>

            <main class="posts-list">
                {
                    filteredPosts.length > 0 ? (
                        <div class="posts-grid">
                            {filteredPosts.map((post) => (
                                <BlogCard post={post} />
                            ))}
                        </div>
                    ) : (
                        <div class="no-results">
                            <p>
                                No posts found for <span class="highlight">{currentTag}</span>.
                            </p>
                            <a href="/blog" class="btn btn-outline mt-4">
                                Show all posts
                            </a>
                        </div>
                    )
                }
            </main>
        </div>
    </div>
</BaseLayout>

<style>
    .blog-archive {
        padding: 6rem 1.5rem;
    }

    .archive-header {
        margin-bottom: 5rem;
        text-align: center;
    }

    .archive-title {
        font-size: 3.5rem;
        font-weight: 800;
        margin-bottom: 1rem;
        letter-spacing: -0.05em;
    }

    .archive-subtitle {
        color: var(--text-muted);
        font-size: 1.25rem;
        max-width: 600px;
        margin: 0 auto;
    }

    .archive-layout {
        display: grid;
        grid-template-columns: 280px 1fr;
        gap: 4rem;
    }

    .sidebar {
        position: sticky;
        top: 100px;
        height: fit-content;
    }

    .sidebar-section {
        margin-bottom: 3rem;
    }

    .sidebar-label {
        font-size: 0.75rem;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 0.1em;
        color: var(--text-muted);
        margin-bottom: 1.25rem;
    }

    .search-box {
        position: relative;
    }

    .search-box input {
        width: 100%;
        padding: 0.75rem 1rem 0.75rem 2.75rem;
        border-radius: var(--radius-md);
        border: 1px solid var(--border-color);
        background: var(--bg-color);
        color: var(--text-color);
        font-family: inherit;
        font-size: 0.95rem;
        transition: var(--transition);
    }

    .search-box input:focus {
        outline: none;
        border-color: var(--color-primary);
        box-shadow: 0 0 0 4px var(--color-primary-soft);
    }

    .search-icon {
        position: absolute;
        left: 1rem;
        top: 50%;
        transform: translateY(-50%);
        color: var(--text-muted);
        pointer-events: none;
    }

    .tag-list {
        list-style: none;
        display: flex;
        flex-direction: column;
        gap: 0.25rem;
    }

    .tag-list a {
        padding: 0.6rem 1rem;
        border-radius: var(--radius-md);
        display: flex;
        justify-content: space-between;
        align-items: center;
        color: var(--text-muted);
        font-weight: 500;
        font-size: 0.95rem;
        transition: var(--transition);
    }

    .tag-list a:hover {
        background-color: var(--color-gray-100);
        color: var(--text-color);
    }

    .tag-list a.active {
        background-color: var(--color-primary-soft);
        color: var(--color-primary);
        font-weight: 600;
    }

    :global([data-theme="dark"]) .tag-list a:hover {
        background-color: var(--color-gray-800);
    }

    :global([data-theme="dark"]) .tag-list a.active {
        background-color: rgba(255, 107, 0, 0.15);
    }

    .posts-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(320px, 1fr));
        gap: 2.5rem;
    }

    .no-results {
        text-align: center;
        padding: 5rem 2rem;
        background: var(--color-gray-100);
        border-radius: var(--radius-xl);
        color: var(--text-muted);
    }

    .highlight {
        color: var(--color-primary);
        font-weight: 700;
    }

    @media (max-width: 1024px) {
        .archive-layout {
            grid-template-columns: 1fr;
            gap: 3rem;
        }
        .sidebar {
            position: static;
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 2rem;
        }
        .sidebar-section {
            margin-bottom: 0;
        }
    }

    @media (max-width: 640px) {
        .sidebar {
            grid-template-columns: 1fr;
        }
    }
</style>

<script>
    const setupSearch = () => {
        const searchInput = document.getElementById("blog-search") as HTMLInputElement;
        const cards = document.querySelectorAll(".blog-card");

        searchInput?.addEventListener("input", (e) => {
            const query = (e.target as HTMLInputElement).value.toLowerCase();

            cards.forEach((card) => {
                const title = (card.querySelector(".card-title") as HTMLElement).innerText.toLowerCase();
                const desc = (card.querySelector(".card-description") as HTMLElement).innerText.toLowerCase();

                if (title.includes(query) || desc.includes(query)) {
                    (card as HTMLElement).style.display = "";
                    (card as HTMLElement).classList.add("fade-in");
                } else {
                    (card as HTMLElement).style.display = "none";
                }
            });
        });
    };

    setupSearch();
    document.addEventListener("astro:after-swap", setupSearch);
</script>
