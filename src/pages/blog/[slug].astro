---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { getPostBySlug } from "../../lib/posts";
import { marked } from "marked";

const { slug } = Astro.params;
const post = await getPostBySlug(slug as string);

if (!post) {
    return Astro.redirect("/404");
}

const htmlContent = marked.parse(post.content);
const formattedDate = new Date(post.date).toLocaleDateString("en-US", {
    year: "numeric",
    month: "long",
    day: "numeric",
});
---

<BaseLayout title={post.title} description={post.description} ogImage={`/api/og?title=${encodeURIComponent(post.title)}`}>
    <script
        type="application/ld+json"
        is:inline
        set:html={JSON.stringify({
            "@context": "https://schema.org",
            "@type": "BlogPosting",
            headline: post.title,
            description: post.description,
            image: [`/api/og?title=${encodeURIComponent(post.title)}`],
            datePublished: post.date,
            author: [
                {
                    "@type": "Person",
                    name: post.author,
                    url: "https://fanblog.com",
                },
            ],
        })}
    />
    <article class="post-content container">
        <header class="post-header">
            <div class="post-meta">
                <a href={`/blog/category/${post.category || "General"}`} class="category-link">{post.category || "General"}</a>
                <span class="dot">•</span>
                <span>{post.readingTime}</span>
            </div>
            <h1>{post.title}</h1>
            <div class="post-author">
                <div class="author-info">
                    <a href={`/author/${post.author}`} class="author-name">By {post.author}</a>
                    <span class="post-date">{formattedDate}</span>
                </div>
            </div>
            {post.image && <img src={post.image} alt={post.title} class="featured-image" />}
        </header>

        <div class="content markdown-body" set:html={htmlContent} />

        <footer class="post-footer">
            <div class="tags">
                {
                    post.tags.map((tag) => (
                        <a href={`/blog/tag/${tag}`} class="tag">
                            #{tag}
                        </a>
                    ))
                }
            </div>
        </footer>
    </article>
</BaseLayout>

<style>
    .post-header {
        padding: 4rem 0 2rem;
        text-align: center;
        max-width: 800px;
        margin: 0 auto;
    }

    .post-meta {
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 0.5rem;
        font-size: 0.9rem;
        font-weight: 600;
        margin-bottom: 1rem;
        text-transform: uppercase;
    }

    .category-link {
        color: var(--color-primary);
        text-decoration: none;
        transition: opacity 0.2s;
    }

    .category-link:hover {
        opacity: 0.8;
        text-decoration: underline;
    }

    .dot {
        color: var(--color-primary);
    }

    h1 {
        font-size: 3.5rem;
        font-weight: 800;
        margin-bottom: 1.5rem;
        line-height: 1.1;
    }

    .author-info {
        display: flex;
        flex-direction: column;
        gap: 0.25rem;
        margin-bottom: 2rem;
    }

    .author-name {
        font-weight: 600;
    }

    .post-date {
        font-size: 0.9rem;
        opacity: 0.6;
    }

    .featured-image {
        width: 100%;
        border-radius: 16px;
        margin: 2rem 0;
        box-shadow: 0 20px 40px rgba(0, 0, 0, 0.1);
    }

    .content {
        max-width: 800px;
        margin: 0 auto;
        font-size: 1.15rem;
        line-height: 1.8;
    }

    /* Markdown Styles */
    .markdown-body :global(h2) {
        margin-top: 2rem;
        margin-bottom: 1rem;
        border-bottom: 1px solid var(--border-color);
        padding-bottom: 0.5rem;
    }
    .markdown-body :global(p) {
        margin-bottom: 1.5rem;
    }
    .markdown-body :global(img) {
        max-width: 100%;
        border-radius: 8px;
        margin: 2rem 0;
    }
    .markdown-body :global(code) {
        background: var(--color-gray-100);
        padding: 0.2rem 0.4rem;
        border-radius: 4px;
        font-size: 0.9em;
    }
    .markdown-body :global(pre) {
        background: var(--color-black);
        color: white;
        padding: 1.5rem;
        border-radius: 8px;
        overflow-x: auto;
        margin: 1.5rem 0;
    }
    .markdown-body :global(ul, ol) {
        margin-bottom: 1.5rem;
        padding-left: 2rem;
    }
    .markdown-body :global(blockquote) {
        border-left: 4px solid var(--color-primary);
        padding-left: 1.5rem;
        font-style: italic;
        margin: 1.5rem 0;
        opacity: 0.9;
    }

    :global([data-theme="dark"]) .markdown-body :global(code) {
        background: var(--color-gray-800);
    }

    .post-footer {
        max-width: 800px;
        margin: 4rem auto 0;
        padding-top: 2rem;
        border-top: 1px solid var(--border-color);
    }

    .tags {
        display: flex;
        gap: 0.75rem;
        flex-wrap: wrap;
    }

    .tag {
        background-color: var(--card-bg);
        padding: 0.4rem 1rem;
        border-radius: 20px;
        font-size: 0.9rem;
        font-weight: 500;
        border: 1px solid var(--border-color);
    }

    @media (max-width: 768px) {
        h1 {
            font-size: 2.5rem;
        }
    }
</style>
