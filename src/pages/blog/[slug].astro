---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { getPostBySlug } from "../../lib/posts";
import { marked } from "marked";

const { slug } = Astro.params;
const post = await getPostBySlug(slug as string);

if (!post) {
    return Astro.redirect("/404");
}

const htmlContent = marked.parse(post.content);
const formattedDate = new Date(post.date).toLocaleDateString("en-US", {
    year: "numeric",
    month: "long",
    day: "numeric",
});

const ogImage = `/api/og?title=${encodeURIComponent(post.title)}`;
---

<BaseLayout 
    title={post.title} 
    description={post.description} 
    ogImage={ogImage}
>
    <!-- Schema.org for Google -->
    <script
        type="application/ld+json"
        is:inline
        set:html={JSON.stringify({
            "@context": "https://schema.org",
            "@type": "BlogPosting",
            headline: post.title,
            description: post.description,
            image: [ogImage],
            datePublished: post.date,
            author: [
                {
                    "@type": "Person",
                    name: post.author,
                    url: Astro.site || "https://fanblog.com",
                },
            ],
        })}
    />

    <article class="post-article fade-in">
        <header class="post-header container">
            <div class="post-meta">
                <span class="category">{post.category || "General"}</span>
                <span class="dot">&middot;</span>
                <span class="reading-time">{post.readingTime}</span>
            </div>
            
            <h1 class="post-title">{post.title}</h1>
            
            <div class="post-author-row">
                <div class="author-details">
                    <span class="author-label">Written by</span>
                    <span class="author-name">{post.author}</span>
                </div>
                <time datetime={post.date} class="post-date">{formattedDate}</time>
            </div>

            {post.image && (
                <div class="featured-image-wrapper">
                    <img src={post.image} alt={post.title} class="featured-image" />
                </div>
            )}
        </header>

        <div class="post-body container">
            <div class="content markdown-body" set:html={htmlContent} />
        </div>

        <footer class="post-footer container">
            <div class="footer-tags">
                <span class="tags-label">Tagged in:</span>
                <div class="tags-list">
                    {post.tags.map((tag) => (
                        <a href={`/blog?tag=${tag}`} class="tag-pill">
                            #{tag}
                        </a>
                    ))}
                </div>
            </div>
            
            <div class="post-share">
                <p>Enjoyed this article? Share it with your network.</p>
                <!-- Share buttons could go here in a real app -->
            </div>
        </footer>
    </article>
</BaseLayout>

<style>
    .post-article {
        padding: 4rem 0 8rem;
    }

    .post-header {
        max-width: 840px;
        text-align: center;
        margin-bottom: 4rem;
    }

    .post-meta {
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 0.5rem;
        font-size: 0.85rem;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 0.1em;
        margin-bottom: 2rem;
        color: var(--text-muted);
    }

    .category {
        color: var(--color-primary);
    }

    .post-title {
        font-size: 4rem;
        font-weight: 900;
        line-height: 1.1;
        margin-bottom: 2.5rem;
        letter-spacing: -0.04em;
    }

    .post-author-row {
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 1.5rem;
        font-size: 1rem;
        color: var(--text-muted);
        margin-bottom: 3rem;
    }

    .author-details {
        display: flex;
        gap: 0.4rem;
    }

    .author-name {
        color: var(--text-color);
        font-weight: 600;
    }

    .featured-image-wrapper {
        margin: 2rem 0;
        border-radius: var(--radius-xl);
        overflow: hidden;
        box-shadow: var(--card-shadow-hover);
        aspect-ratio: 16 / 9;
    }

    .featured-image {
        width: 100%;
        height: 100%;
        object-fit: cover;
    }

    .post-body {
        max-width: 800px;
        margin: 0 auto 6rem;
    }

    .content {
        font-size: 1.25rem;
        line-height: 1.75;
        color: var(--text-color);
    }

    /* Markdown Enhancements */
    .markdown-body :global(h2) {
        font-size: 2.25rem;
        margin-top: 3.5rem;
        margin-bottom: 1.5rem;
    }

    .markdown-body :global(h3) {
        font-size: 1.75rem;
        margin-top: 2.5rem;
        margin-bottom: 1rem;
    }

    .markdown-body :global(p) {
        margin-bottom: 1.75rem;
    }

    .markdown-body :global(blockquote) {
        border-left: 4px solid var(--color-primary);
        padding: 1.5rem 2rem;
        background-color: var(--color-gray-100);
        font-style: italic;
        border-radius: 0 var(--radius-md) var(--radius-md) 0;
        margin: 2.5rem 0;
    }

    :global([data-theme="dark"]) .markdown-body :global(blockquote) {
        background-color: var(--color-gray-900);
    }

    .markdown-body :global(pre) {
        background-color: #0f172a;
        color: #f8fafc;
        padding: 2rem;
        border-radius: var(--radius-lg);
        font-size: 1rem;
        margin: 2.5rem 0;
        overflow-x: auto;
    }

    .markdown-body :global(code:not(pre code)) {
        background-color: var(--color-primary-soft);
        color: var(--color-primary);
        padding: 0.2rem 0.4rem;
        border-radius: 4px;
        font-size: 0.9em;
        font-weight: 600;
    }

    :global([data-theme="dark"]) .markdown-body :global(code:not(pre code)) {
        background-color: rgba(255, 107, 0, 0.1);
    }

    .post-footer {
        max-width: 800px;
        border-top: 1px solid var(--border-color);
        padding-top: 4rem;
        margin: 0 auto;
    }

    .footer-tags {
        display: flex;
        flex-direction: column;
        gap: 1rem;
        margin-bottom: 4rem;
    }

    .tags-label {
        font-size: 0.75rem;
        font-weight: 700;
        text-transform: uppercase;
        color: var(--text-muted);
        letter-spacing: 0.1em;
    }

    .tags-list {
        display: flex;
        gap: 0.75rem;
        flex-wrap: wrap;
    }

    .tag-pill {
        padding: 0.5rem 1.25rem;
        background-color: var(--color-gray-100);
        border: 1px solid var(--border-color);
        border-radius: 2rem;
        font-size: 0.9rem;
        font-weight: 500;
        color: var(--text-muted);
        transition: var(--transition);
    }

    .tag-pill:hover {
        border-color: var(--color-primary);
        color: var(--color-primary);
        background-color: var(--color-primary-soft);
    }

    :global([data-theme="dark"]) .tag-pill { background-color: var(--color-gray-900); }

    .post-share {
        text-align: center;
        padding: 3rem;
        background-color: var(--color-gray-100);
        border-radius: var(--radius-xl);
    }

    :global([data-theme="dark"]) .post-share { background-color: var(--color-gray-900); }

    .post-share p {
        font-weight: 600;
        color: var(--text-color);
    }

    @media (max-width: 768px) {
        .post-article { padding: 3rem 0 6rem; }
        .post-title { font-size: 2.75rem; }
        .post-header { margin-bottom: 3rem; }
        .post-author-row { flex-direction: column; gap: 0.5rem; }
        .content { font-size: 1.15rem; }
    }
</style>
