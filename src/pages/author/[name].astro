---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { getAuthor } from "../../lib/authors";
import { getAllPosts } from "../../lib/posts";
import BlogCard from "../../components/BlogCard.astro";

const { name } = Astro.params;
const author = getAuthor(name as string);

if (!author) {
    return Astro.redirect("/404");
}

const allPosts = await getAllPosts();
const authorPosts = allPosts.filter((post) => post.author.toLowerCase() === name?.toLowerCase());
---

<BaseLayout title={author.name} description={author.bio}>
    <div class="container author-profile">
        <header class="author-header">
            <div class="author-card">
                <div class="author-avatar">
                    {author.name.charAt(0)}
                </div>
                <div class="author-info-large">
                    <span class="author-role">{author.role}</span>
                    <h1>{author.name}</h1>
                    <p class="author-bio">{author.bio}</p>
                </div>
            </div>
        </header>

        <section class="author-posts">
            <h2>Recent Posts by {author.name}</h2>
            <div class="posts-grid">
                {authorPosts.map((post) => <BlogCard post={post} />)}
            </div>
        </section>
    </div>
</BaseLayout>

<style>
    .author-profile {
        padding: 4rem 1.5rem;
    }
    .author-header {
        margin-bottom: 4rem;
    }

    .author-card {
        display: flex;
        align-items: center;
        gap: 3rem;
        background: var(--card-bg);
        padding: 3rem;
        border-radius: 20px;
        border: 1px solid var(--border-color);
        box-shadow: var(--card-shadow);
    }

    .author-avatar {
        width: 150px;
        height: 150px;
        background: var(--color-primary);
        color: white;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 4rem;
        font-weight: 800;
    }

    .author-info-large {
        flex: 1;
    }
    .author-role {
        color: var(--color-primary);
        font-weight: 700;
        text-transform: uppercase;
        font-size: 0.9rem;
    }
    h1 {
        font-size: 3rem;
        margin: 0.5rem 0 1rem;
    }
    .author-bio {
        font-size: 1.2rem;
        opacity: 0.8;
        line-height: 1.6;
    }

    h2 {
        margin-bottom: 2rem;
        font-size: 2rem;
    }
    .posts-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
        gap: 2rem;
    }

    @media (max-width: 768px) {
        .author-card {
            flex-direction: column;
            text-align: center;
            gap: 1.5rem;
            padding: 2rem;
        }
        .author-avatar {
            width: 100px;
            height: 100px;
            font-size: 2.5rem;
        }
    }
</style>
