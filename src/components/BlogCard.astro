---
import type { Post } from "../lib/posts";

interface Props {
    post: Post;
}

const { post } = Astro.props;
const formattedDate = new Date(post.date).toLocaleDateString("en-US", {
    year: "numeric",
    month: "long",
    day: "numeric",
});
---

<article class="blog-card">
    <div class="card-image-wrapper">
        <a href={`/blog/${post.slug}`}>
            {
                post.image ? (
                    <img src={post.image} alt={post.title} class="card-image" loading="lazy" />
                ) : (
                    <div class="card-image-placeholder">
                        <span>{post.title.charAt(0)}</span>
                    </div>
                )
            }
        </a>
    </div>
    <div class="card-content">
        <div class="card-meta">
            <a href={`/blog/category/${post.category || "General"}`} class="tag">{post.category || "General"}</a>
            <span class="dot">•</span>
            <span>{post.readingTime}</span>
        </div>
        <a href={`/blog/${post.slug}`}><h3 class="card-title">{post.title}</h3></a>
        <p class="card-description">{post.description}</p>
        <div class="card-footer">
            <a href={`/author/${post.author}`} class="author-link">{post.author}</a>
            <span class="date">{formattedDate}</span>
        </div>
    </div>
</article>

<style>
    .blog-card {
        background-color: var(--card-bg);
        border-radius: 12px;
        overflow: hidden;
        transition:
            transform 0.3s ease,
            box-shadow 0.3s ease;
        border: 1px solid var(--border-color);
    }

    .blog-card:hover {
        transform: translateY(-5px);
        box-shadow: 0 10px 30px rgba(0, 0, 0, 0.1);
        border-color: var(--color-primary);
    }

    .card-image,
    .card-image-placeholder {
        width: 100%;
        height: 200px;
        object-fit: cover;
    }

    .card-image-placeholder {
        background: linear-gradient(135deg, var(--color-primary), var(--color-black));
        display: flex;
        align-items: center;
        justify-content: center;
        color: white;
        font-size: 3rem;
        font-weight: 800;
    }

    .card-content {
        padding: 1.5rem;
    }

    .card-meta {
        display: flex;
        align-items: center;
        gap: 0.5rem;
        font-size: 0.8rem;
        font-weight: 600;
        margin-bottom: 0.5rem;
        text-transform: uppercase;
    }

    .tag {
        color: var(--color-primary);
        background-color: rgba(255, 107, 0, 0.1);
        padding: 2px 8px;
        border-radius: 4px;
        transition: background-color 0.2s;
    }

    .tag:hover {
        background-color: var(--color-primary);
        color: white;
    }

    .card-title {
        font-size: 1.25rem;
        margin-bottom: 0.75rem;
        color: var(--text-color);
        transition: color 0.2s;
    }

    .card-title:hover {
        color: var(--color-primary);
    }

    .card-description {
        font-size: 0.95rem;
        color: var(--text-color);
        opacity: 0.7;
        display: -webkit-box;
        -webkit-line-clamp: 2;
        -webkit-box-orient: vertical;
        overflow: hidden;
        margin-bottom: 1rem;
    }

    .card-footer {
        display: flex;
        justify-content: space-between;
        align-items: center;
        font-size: 0.8rem;
        padding-top: 1rem;
        border-top: 1px solid var(--border-color);
    }

    .author-link {
        font-weight: 700;
        color: var(--text-color);
        transition: color 0.2s;
    }

    .author-link:hover {
        color: var(--color-primary);
    }

    .date {
        opacity: 0.6;
    }
</style>
