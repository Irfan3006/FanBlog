---
import ThemeToggle from "./ThemeToggle.astro";
---

<header class="navbar">
    <div class="container nav-content">
        <a href="/" class="logo" aria-label="FanBlog Home">
            <span class="logo-fan">Fan</span><span class="logo-blog">Blog</span>
        </a>
        <nav class="desktop-nav">
            <ul class="nav-links">
                <li><a href="/" class="nav-link">Home</a></li>
                <li><a href="/blog" class="nav-link">Blog</a></li>
                <li><a href="/admin" class="admin-link">Admin</a></li>
                <li class="theme-toggle-li"><ThemeToggle /></li>
            </ul>
        </nav>

        <div class="mobile-actions">
            <ThemeToggle />
            <button class="mobile-menu-toggle" aria-label="Toggle Menu" aria-expanded="false">
                <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="menu-icon">
                    <line x1="3" y1="12" x2="21" y2="12" class="line-middle"></line>
                    <line x1="3" y1="6" x2="21" y2="6" class="line-top"></line>
                    <line x1="3" y1="18" x2="21" y2="18" class="line-bottom"></line>
                </svg>
            </button>
        </div>
    </div>
</header>

<!-- Mobile Menu Overlay — outside <header> to avoid sticky stacking context -->
<div class="mobile-menu-overlay" aria-hidden="true">
    <button class="mobile-menu-close" aria-label="Close Menu">
        <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
            <line x1="18" y1="6" x2="6" y2="18"></line>
            <line x1="6" y1="6" x2="18" y2="18"></line>
        </svg>
    </button>
    <nav class="mobile-nav">
        <ul class="mobile-nav-links">
            <li><a href="/">Home</a></li>
            <li><a href="/blog">Blog</a></li>
            <li><a href="/admin">Admin Panel</a></li>
        </ul>
    </nav>
</div>

<script>
    const closeMenu = () => {
        const toggle = document.querySelector('.mobile-menu-toggle') as HTMLElement;
        const overlay = document.querySelector('.mobile-menu-overlay') as HTMLElement;
        if (!toggle || !overlay) return;
        toggle.setAttribute('aria-expanded', 'false');
        toggle.classList.remove('active');
        overlay.setAttribute('aria-hidden', 'true');
        overlay.classList.remove('active');
        document.body.style.overflow = '';
    };

    const setupMenu = () => {
        const toggle = document.querySelector('.mobile-menu-toggle');
        const overlay = document.querySelector('.mobile-menu-overlay');
        const closeBtn = document.querySelector('.mobile-menu-close');
        const body = document.body;

        if (!toggle || !overlay) return;

        const handleToggle = () => {
            const isExpanded = toggle.getAttribute('aria-expanded') === 'true';
            const nextState = !isExpanded;
            
            toggle.setAttribute('aria-expanded', nextState.toString());
            toggle.classList.toggle('active', nextState);
            overlay.setAttribute('aria-hidden', (!nextState).toString());
            overlay.classList.toggle('active', nextState);
            body.style.overflow = nextState ? 'hidden' : '';
        };

        toggle.addEventListener('click', handleToggle);

        // Close via X button
        closeBtn?.addEventListener('click', closeMenu);

        // Close menu when clicking a link
        overlay.querySelectorAll('a').forEach(link => {
            link.addEventListener('click', closeMenu);
        });
    };

    setupMenu();
    document.addEventListener('astro:after-swap', setupMenu);
</script>

<style>
    .navbar {
        position: sticky;
        top: 0;
        z-index: 1000;
        background-color: var(--nav-bg);
        backdrop-filter: blur(12px);
        -webkit-backdrop-filter: blur(12px);
        border-bottom: 1px solid var(--border-color);
        padding: 0.75rem 0;
        transition: var(--transition);
        height: 64px;
        display: flex;
        align-items: center;
    }

    .nav-content {
        display: flex;
        justify-content: space-between;
        align-items: center;
        width: 100%;
    }

    .logo {
        font-size: 1.5rem;
        font-weight: 800;
        letter-spacing: -0.05em;
        display: flex;
        align-items: center;
        z-index: 1001;
    }

    .logo-fan {
        color: var(--color-primary);
    }
    .logo-blog {
        color: var(--text-color);
    }

    .nav-links {
        display: flex;
        align-items: center;
        list-style: none;
        gap: 2.5rem;
    }

    .nav-link {
        font-weight: 500;
        font-size: 0.95rem;
        color: var(--text-muted);
    }

    .nav-link:hover {
        color: var(--color-primary);
    }

    .admin-link {
        background-color: var(--color-black);
        color: var(--color-white) !important;
        padding: 0.5rem 1.25rem;
        border-radius: var(--radius-md);
        font-size: 0.9rem;
        font-weight: 600;
    }

    :global([data-theme="dark"]) .admin-link {
        background-color: var(--color-white);
        color: var(--color-black) !important;
    }

    .theme-toggle-li {
        display: flex;
        align-items: center;
    }

    .mobile-actions {
        display: none;
        align-items: center;
        gap: 0.5rem;
        z-index: 10000;
    }

    .mobile-menu-toggle {
        background: none;
        border: none;
        color: var(--text-color);
        cursor: pointer;
        padding: 0.5rem;
        display: flex;
        align-items: center;
        justify-content: center;
        position: relative;
    }

    .menu-icon line {
        transition: transform 0.3s ease, opacity 0.3s ease;
        transform-origin: center;
    }

    .mobile-menu-toggle.active .line-top {
        transform: translateY(6px) rotate(45deg);
    }

    .mobile-menu-toggle.active .line-middle {
        opacity: 0;
    }

    .mobile-menu-toggle.active .line-bottom {
        transform: translateY(-6px) rotate(-45deg);
    }

    .mobile-menu-overlay {
        position: fixed;
        inset: 0;
        background-color: rgba(255, 255, 255, 0.95);
        z-index: 9999;
        display: none;
        padding: 10rem 2rem 2rem;
        backdrop-filter: blur(40px);
        -webkit-backdrop-filter: blur(40px);
        animation: fadeIn 0.4s cubic-bezier(0.16, 1, 0.3, 1);
    }

    :global([data-theme="dark"]) .mobile-menu-overlay {
        background-color: rgba(5, 5, 5, 0.95);
    }

    .mobile-menu-overlay.active {
        display: block;
    }

    .mobile-menu-close {
        position: absolute;
        top: 1.25rem;
        right: 1.25rem;
        background: none;
        border: none;
        cursor: pointer;
        color: var(--text-color);
        padding: 0.5rem;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        transition: background 0.2s, color 0.2s;
        z-index: 10001;
    }

    .mobile-menu-close:hover {
        background-color: var(--border-color);
        color: var(--color-primary);
    }

    .mobile-nav-links {
        list-style: none;
        display: flex;
        flex-direction: column;
        gap: 2rem;
        align-items: center;
    }

    .mobile-nav-links a {
        font-size: 2rem;
        font-weight: 800;
        color: var(--text-color);
        letter-spacing: -0.02em;
    }

    @media (max-width: 768px) {
        .navbar {
            padding: 0.5rem 0;
        }
        .desktop-nav {
            display: none;
        }
        .mobile-actions {
            display: flex;
        }
    }

    /* Accessibility: Hide overlay from screen readers when not active */
    .mobile-menu-overlay[aria-hidden="true"] {
        visibility: hidden;
        pointer-events: none;
    }
    
    .mobile-menu-overlay[aria-hidden="false"] {
        visibility: visible;
        pointer-events: auto;
    }
</style>
